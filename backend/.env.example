# Variables d'entorn del backend TouristTech
# Copia aquest fitxer com a .env i omple els valors reals

# Port del servidor (per defecte: 3000)
PORT=3000

# ---- APIs de Google Cloud (per a la versió real) ----
# Clau d'API de Google Cloud (o usa Application Default Credentials)
GOOGLE_CLOUD_PROJECT_ID=el-teu-project-id

# Per a Cloud Vision, Translation i Text-to-Speech
GOOGLE_API_KEY=la-teva-api-key

# Per a Vertex AI (Gemini)
VERTEX_AI_LOCATION=europe-west1
