# Cloud Function – Environment Variables
# Copy this to .env for local testing (never commit to git!)

GCP_PROJECT_ID=touristtech-prod
GCP_LOCATION=us-central1
GCP_IMAGES_BUCKET=touristtech-menu-images
GCP_AUDIO_BUCKET=touristtech-audio-output
GEMINI_MODEL=gemini-1.5-pro

# Cloud SQL (use Unix socket path in production, IP for local dev)
DB_HOST=/cloudsql/touristtech-prod:us-central1:touristtech-db
DB_PORT=5432
DB_NAME=touristtech
DB_USER=touristtech_user
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE

NODE_ENV=production
